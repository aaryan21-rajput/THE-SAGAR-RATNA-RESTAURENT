# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The URL of your Supabase project
SUPABASE_URL="https://xykdbtebmjzapaozsggl.supabase.co"

# SUPABASE_ANON_KEY: Your Supabase anonymous/public API key
SUPABASE_ANON_KEY="sb_publishable_MbOmjXCRkgLRdic8YE-8ng_RyBIkI7G"

# JWT_SECRET: Secret key for signing and verifying JWT authentication tokens
JWT_SECRET="sagar_ratna_super_secure_key_2026_unbreakable_secret"

# Backend Admin Credentials (defaults to aaryanrajputofficial@gmail.com)
ADMIN_EMAIL="aaryanrajputofficial@gmail.com"

# Backend Admin Password Hash: Cryptographically hashed password (SHA-256 of Admin@12345)
ADMIN_PASSWORD_HASH="6f2cb9dd8f4b65e24e1c3f3fa5bc57982349237f11abceacd45bbcb74d621c25"

# Frontend Admin Credentials (Vite-prefixed for offline fallback)
